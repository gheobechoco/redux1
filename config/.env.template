# Runtime configuration
APP_NAME="Will It Rain On My Parade API"
ENVIRONMENT=development
LOG_LEVEL=INFO

# CORS (comma-separated or *)
CORS_ORIGINS=*

# NASA Earthdata Login (EDL) credentials
EARTHDATA_USERNAME=
EARTHDATA_PASSWORD=

# Optional: Redis for caching
# e.g., redis://localhost:6379/0
REDIS_URL=

# NASA endpoints (override if needed)
CMR_BASE_URL=https://cmr.earthdata.nasa.gov
GES_DISC_BASE_URL=https://disc.gsfc.nasa.gov
POWER_BASE_URL=https://power.larc.nasa.gov/api/temporal/daily/point

# Data period
START_YEAR=2000
END_YEAR=2023
